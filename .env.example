# Copie vers `.env.local` pour le dev local (ne jamais committer `.env.local`).
# Sur Vercel : pas d’émulateur — utilise la vraie config Firebase / Inforge.

# URL canonique du site (SEO / Open Graph) — ex. https://mindstress-app.vercel.app
# NEXT_PUBLIC_SITE_URL=

# --- Google AI (serveur uniquement) — Dr. Mind ---
GEMINI_API_KEY=

# --- BD 100 % locale (Firebase Emulator : Firestore + Auth sur ta machine) ---
# Mets "true" pour pointer vers l’émulateur (lance `npm run emulators` dans un autre terminal).
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# Optionnel — hôtes / ports si tu changes firebase.json
# NEXT_PUBLIC_FIREBASE_EMULATOR_HOST=127.0.0.1
# NEXT_PUBLIC_FIRESTORE_EMULATOR_PORT=8080
# NEXT_PUBLIC_AUTH_EMULATOR_PORT=9099

# Identifiant d’app (chemins /artifacts/{appId}/...) — en émulateur, défaut "local" si vide
NEXT_PUBLIC_APP_ID=local

# Sans émulateur : config Firebase réelle (JSON une ligne ou base64)
# NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...",...}
# NEXT_PUBLIC_FIREBASE_CONFIG_B64=

# Optionnel — prod / Inforge uniquement
# NEXT_PUBLIC_INITIAL_AUTH_TOKEN=

# --- PostgreSQL (Insforge / serveur uniquement, jamais NEXT_PUBLIC_) ---
# Ne mets jamais le mot de passe dans le code ni dans un commit. Rotation si fuite.
# DATABASE_URL=postgresql://USER:MOT_DE_PASSE@HOST:5432/insforge?sslmode=require

# --- InsForge SDK (@insforge/sdk) — après `npm run insforge:metadata` ou le dashboard ---
# URL de l’API (souvent https://<id>.<region>.insforge.app sans le / final)
# NEXT_PUBLIC_INSFORGE_URL=
# Clé anonyme (safe côté navigateur)
# NEXT_PUBLIC_INSFORGE_ANON_KEY=
